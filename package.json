{
  "name": "purchase-requisition-system",
  "version": "1.0.0",
  "description": "Google Apps Script Purchase Request System bound to a Google Sheet with Form submissions",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "create": "clasp create --title \"Purchase Requisition System\" --type sheets --rootDir dist",
    "push": "npm run build && cp appsscript.json dist/appsscript.json && clasp push",
    "pull": "clasp pull && cp dist/appsscript.json appsscript.json",
    "status": "clasp status",
    "logs": "clasp logs --watch",
    "open": "clasp open",
    "clean": "rm -rf dist",
    "upgrade": "npx npm-check-updates -u"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afrotc-det225/purchase-requisition-system.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/afrotc-det225/purchase-requisition-system/issues"
  },
  "homepage": "https://github.com/afrotc-det225/purchase-requisition-system#readme",
  "devDependencies": {
    "@types/google-apps-script": "^2.0.8",
    "npm-check-updates": "^19.3.1",
    "typescript": "^5.9.3"
  }
}
